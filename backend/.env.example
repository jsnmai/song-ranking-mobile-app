# Copy to `.env` for local dev, or set these as host environment variables in
# production. Every variable without a default is REQUIRED and validated by
# src/core/config.py:Settings on startup — a missing one fails fast at boot.
# Never commit a real .env (it is gitignored).

# --- Required ---------------------------------------------------------------

# PostgreSQL connection string for SQLAlchemy (sync, psycopg2 driver).
# Accepted schemes:
#   postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME   (explicit, preferred)
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME            (also works — SQLAlchemy
#                                                            defaults to psycopg2)
# Do NOT use +asyncpg or +psycopg (v3): only psycopg2-binary is installed.
# Managed hosts (e.g. Railway Postgres) hand you a `postgresql://...` URL, which
# works as-is; add `+psycopg2` only if you want it explicit.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/listn

# Secret used to sign JWTs (HS256). Generate a strong value per environment:
#   openssl rand -hex 32
JWT_SECRET_KEY=<generate with: openssl rand -hex 32>

# Single allowed CORS origin for this environment. Locally this is the Expo dev
# server. (Native mobile clients do not enforce CORS, but keep it set correctly.)
CORS_ORIGINS=http://localhost:8081

# --- Optional (have defaults in Settings; omit unless you need to override) --

# JWT signing algorithm. Default: HS256
# JWT_ALGORITHM=HS256

# Access-token lifetime in days (no refresh tokens yet). Default: 7
# JWT_EXPIRY_DAYS=7

# Kill-switch for the weekly-streak finalize side effect + read surface. Default: true
# STREAKS_ENABLED=true

# --- Password reset / transactional email (all optional) --------------------
#
# Pluggable email backend, chosen with EMAIL_PROVIDER:
#   console (default): log the message (incl. the reset code) instead of sending.
#                      No setup; used for local dev and tests.
#   smtp:              send via SMTP (e.g. Gmail with an App Password). Free, no
#                      domain needed. Good for MVP / low volume. (Current choice.)
#   resend:            send via the Resend API. Best deliverability; needs a
#                      verified sending domain.
# A real provider (smtp/resend) chosen without its credentials fails closed —
# it logs a warning and drops the message rather than logging the reset code, so
# a missing secret never leaks a live code. Only "console" logs the code, and it
# is dev/test-only — never set EMAIL_PROVIDER=console in production.
# EMAIL_PROVIDER=smtp

# --- SMTP backend (EMAIL_PROVIDER=smtp), e.g. Gmail -------------------------
# Gmail needs 2-factor auth on the account, then a 16-char "App Password"
# generated at https://myaccount.google.com/apppasswords . Host/port defaults
# below work for Gmail. Set EMAIL_FROM to the SAME address (Gmail sends From the
# authenticated account). Consumer Gmail caps at ~500 emails/day.
# SMTP_USERNAME=your-app@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# --- Resend backend (EMAIL_PROVIDER=resend) --------------------------------
# Resend API key. Needs a verified sending domain (SPF/DKIM) to reach arbitrary
# users; the sandbox sender only reaches your own Resend account address.
#   https://resend.com → API Keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From address for outbound email. For smtp: the authenticated account
# (e.g. "LISTn <your-app@gmail.com>"). For resend: an address on your verified
# domain. Defaults to the Resend sandbox sender.
# EMAIL_FROM=LISTn <onboarding@resend.dev>

# Optional override for the per-email reset-throttle HMAC key. When unset, the
# key is derived from JWT_SECRET_KEY with domain separation — so no new required
# secret is needed. Set this only to rotate the throttle key independently.
#   openssl rand -hex 32
# EMAIL_HASH_PEPPER=<generate with: openssl rand -hex 32>

# Password-reset tunables (defaults shown).
# RESET_CODE_TTL_MINUTES=15
# RESET_CODE_MAX_ATTEMPTS=5
# RESET_RESEND_COOLDOWN_SECONDS=60
# RESET_MAX_REQUESTS_PER_WINDOW=5
# RESET_REQUEST_WINDOW_MINUTES=60
