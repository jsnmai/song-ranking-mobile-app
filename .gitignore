# Python
__pycache__/       # Python's compiled bytecode cache — regenerated automatically
*.pyc              # Compiled Python files
*.pyo              # Optimized compiled Python files
.venv/             # Virtual environment — recreated from pyproject.toml + uv.lock
.pytest_cache/     # Pytest's internal cache — regenerated on each test run
.ruff_cache/       # Ruff linter cache — regenerated automatically
*.egg-info/        # Package metadata generated during installs

# Test Coverage
.coverage          # Raw coverage data file generated by pytest-cov
htmlcov/           # HTML coverage report folder — open htmlcov/index.html to view

# Environment Variables
# Never commit .env files — they contain secrets like JWT keys and DB passwords
# Use .env.example (committed) as a template with placeholder values instead
.env
.env.local
.env.*.local

# Expo / React Native
node_modules/      # JavaScript dependencies — never commit, can be hundreds of MB
.expo/             # Expo dev tools cache — machine-specific, regenerated on start
dist/              # Production build output — generated by build commands
web-build/         # Expo web build output — generated by expo build:web

# Apple Signing Files
# These files are used for App Store publishing and contain private credentials
# They should be stored securely (e.g. in a password manager), never in git
*.p8               # Apple API keys (push notifications, App Store Connect)
*.p12              # Apple distribution certificates
*.mobileprovision  # Apple provisioning profiles

# Android Signing Files
# Keystore files are used to sign Android APKs for the Play Store
# Losing these means you can never update your app — store them safely offline
*.jks              # Java KeyStore — Android signing key
*.keystore         # Alternative keystore extension used by some Android tools

# macOS
.DS_Store          # macOS folder metadata — created automatically by Finder

# IDEs
.vscode/           # VS Code workspace settings — editor-specific, not project config
.idea/             # JetBrains (PyCharm, WebStorm) project files