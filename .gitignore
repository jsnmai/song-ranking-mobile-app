# Python
# Compiled bytecode cache — regenerated automatically
__pycache__/
**/__pycache__/
*.pyc
*.pyo
# Virtual environment — recreated from pyproject.toml + uv.lock
.venv/
# Pytest's internal cache — regenerated on each test run
.pytest_cache/
# Ruff linter cache — regenerated automatically
.ruff_cache/
# Package metadata generated during installs
*.egg-info/

# Test Coverage
# Raw coverage data file generated by pytest-cov
.coverage
# HTML coverage report folder — open htmlcov/index.html to view
htmlcov/

# Environment Variables
# Never commit .env files — they contain secrets like JWT keys and DB passwords
# Use .env.example (committed) as a template with placeholder values instead
.env
.env.local
.env.*.local

# Expo / React Native
# JavaScript dependencies — never commit, can be hundreds of MB
node_modules/
# Expo dev tools cache — machine-specific, regenerated on start
.expo/
# Production build output — generated by build commands
dist/
# Expo web build output — generated by expo build:web
web-build/

# Apple Signing Files
# These files are used for App Store publishing and contain private credentials
# They should be stored securely (e.g. in a password manager), never in git
*.p8
*.p12
*.mobileprovision

# Android Signing Files
# Keystore files are used to sign Android APKs for the Play Store
# Losing these means you can never update your app — store them safely offline
*.jks
*.keystore

# macOS
# macOS folder metadata — created automatically by Finder
.DS_Store

# IDEs
# VS Code workspace settings — editor-specific, not project config
.vscode/
# JetBrains (PyCharm, WebStorm) project files
.idea/

# Internal AI context file
CLAUDE.md
