# Copy to .env for local development (.env is gitignored).
# Only EXPO_PUBLIC_* vars are allowed in the frontend — they are inlined into the
# client bundle and are therefore PUBLIC. Never put secrets here; backend secrets
# live on the server (Railway env vars) only.
#
# Local dev points at the backend running on your machine:
EXPO_PUBLIC_API_URL=http://localhost:8000

# Production / preview values are NOT set here — they come from EAS Environment
# Variables (Expo dashboard → Environment variables, or `eas env:create`) and are
# selected per build/update via the profile's `environment` in eas.json
# (eas update --channel production --environment production).
